			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"Auth": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"Sensitive": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		},
		"AdminMutations": {
			"PermitLimit": 10000,
			"Window": "00:00:10"
		}
